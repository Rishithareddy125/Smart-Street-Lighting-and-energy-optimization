#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <WiFi.h>
#include <ThingSpeak.h>

// Pin Definitions
#define LDR_PIN 34
#define PIR_PIN 27
#define CURRENT_PIN 35
#define LED_PIN 2   // PWM pin
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

// ThingSpeak
const char* ssid = "linitta_elezabath";
const char* password = "Ester45@@";
unsigned long channelID = 3287036;  // ThingSpeak Channel ID
const char* writeAPIKey = "T841P3SFVQFB3QR1";

// OLED setup
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// Thresholds
const int DARK_THRESHOLD = 1500;

// PWM settings for ESP32
int ledChannel = 0;
int ledFreq = 5000;
int ledResolution = 8;

WiFiClient client;

void setup() {
  Serial.begin(115200);
  pinMode(PIR_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);

  // ESP32 PWM setup
  ledcAttach(LED_PIN, ledFreq, ledResolution);

  // OLED setup
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("OLED failed"));
    for(;;);
  }
  display.clearDisplay();
  display.setTextColor(WHITE);

  // Connect WiFi
  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");
  while(WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected to WiFi");

  ThingSpeak.begin(client); // Initialize ThingSpeak
}

void loop() {
  int ldrValue = analogRead(LDR_PIN);
  int motion = digitalRead(PIR_PIN);
  float current = getACSCurrent(CURRENT_PIN);
  int brightness = 0;

  // Logic: Only turn on if it's dark
  if (ldrValue < DARK_THRESHOLD) {
    if (motion == HIGH) {
      brightness = 255; // Full brightness if motion detected
    } else {
      brightness = 50;  // Dim mode
    }
  } else {
    brightness = 0;      // Day time, light OFF
  }

  // Write PWM to LED
  ledcWrite(ledChannel, brightness);

  // Update OLED
  updateOLED(ldrValue, motion, current, brightness);

  // Send data to ThingSpeak
  ThingSpeak.setField(1, ldrValue);
  ThingSpeak.setField(2, motion);
  ThingSpeak.setField(3, current);
  ThingSpeak.setField(4, brightness);
  int response = ThingSpeak.writeFields(channelID, writeAPIKey);
  if(response == 200){
    Serial.println("ThingSpeak update successful");
  } else {
    Serial.println("ThingSpeak update failed");
  }

  delay(15000); // ThingSpeak allows 15s minimum update interval
}

// ACS712 current measurement
float getACSCurrent(int pin) {
  int raw = analogRead(pin);
  float voltage = (raw / 4095.0) * 3.3; // ESP32 12-bit ADC
  return (voltage - 1.65) / 0.185;      // ACS712-05B sensitivity
}

// OLED update
void updateOLED(int ldr, int mot, float curr, int br) {
  display.clearDisplay();
  display.setCursor(0,0);
  display.println("STREET LIGHT SYSTEM");
  display.print("LDR: "); display.println(ldr);
  display.print("Motion: "); display.println(mot ? "YES" : "NO");
  display.print("Current: "); display.print(curr); display.println("A");
  display.print("Status: "); display.println(br > 0 ? "ON" : "OFF");
  display.display();
}